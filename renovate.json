{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "10 days",
  "internalChecksFilter": "strict",
  "schedule": ["before 6am on monday"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "lockFileMaintenance": { "enabled": false },
  "packageRules": [
    {
      "description": "Search Clojars and Maven Central.",
      "matchDatasources": ["clojure"],
      "registryUrls": [
        "https://repo.clojars.org",
        "https://repo.maven.apache.org/maven2"
      ]
    },
    {
      "matchManagers": ["leiningen", "deps-edn"],
      "matchPackageNames": ["com.datadoghq:java-dogstatsd-client"],
      "groupName": "java-dogstatsd-client"
    }
  ],
  "github-actions": { "enabled": true }
}
